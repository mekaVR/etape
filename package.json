{
  "name": "etape",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.5.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-turbo": "^2.9.3"
  },
  "lint-staged": {
    "apps/api/**/*.ts": [
      "bash -c 'cd apps/api && eslint --fix'",
      "prettier --write"
    ],
    "apps/transition-pro/**/*.{ts,tsx}": [
      "bash -c 'cd apps/transition-pro && eslint --fix'",
      "prettier --write"
    ],
    "apps/fongesoft/**/*.{ts,tsx}": [
      "bash -c 'cd apps/fongesoft && eslint --fix'",
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
